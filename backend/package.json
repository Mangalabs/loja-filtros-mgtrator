{
  "name": "loja-filtros-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "dev:build": "npm run build && node dist/main.js",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "test": "NODE_ENV=test node --import tsx --test src/views/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:make": "knex migrate:make --knexfile knexfile.cjs",
    "db:migrate": "knex migrate:latest --knexfile knexfile.cjs",
    "db:rollback": "knex migrate:rollback --knexfile knexfile.cjs"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.14.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "knex": "^3.2.10",
    "pg": "^8.20.0",
    "zod": "^4.4.3"
  }
}
