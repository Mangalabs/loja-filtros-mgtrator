# homologation -> https://homologacao.focusnfe.com.br
# production -> https://api.focusnfe.com.br
# FOCUS_NFE_BASE_URL e legado e so vale para homologacao.
FOCUS_NFE_BASE_URL=
FOCUS_NFE_HOMOLOGATION_BASE_URL=
FOCUS_NFE_PRODUCTION_BASE_URL=
# Compatibilidade: usado quando os tokens por ambiente abaixo estiverem vazios.
FOCUS_NFE_TOKEN=
FOCUS_NFE_HOMOLOGATION_TOKEN=
FOCUS_NFE_PRODUCTION_TOKEN=
FOCUS_NFE_COMPANY_CNPJ=
