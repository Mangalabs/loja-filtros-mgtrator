HOST=127.0.0.1
PORT=3333
DATABASE_URL=postgres://postgres:replace-with-url-encoded-password@127.0.0.1:5433/loja_filtros
TEST_DATABASE_URL=postgres://postgres:replace-with-url-encoded-password@127.0.0.1:5433/loja_filtros_test
JWT_SECRET=replace-with-a-random-secret-of-at-least-32-characters
CORS_ORIGIN=http://127.0.0.1:5173,http://37.59.103.70
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=strict
QUOTE_PDF_STORE_NAME=Filtros MG
QUOTE_PDF_STORE_ADDRESS=Endereco da loja
QUOTE_PDF_STORE_CITY=Cidade/UF
QUOTE_PDF_STORE_DOCUMENT=Documento comercial sem valor fiscal
QUOTE_PDF_STORE_PHONE=
QUOTE_PDF_STORE_EMAIL=
PUPPETEER_EXECUTABLE_PATH=
PUPPETEER_NO_SANDBOX=true
FISCAL_PROVIDER=mock
FISCAL_ENVIRONMENT=homologation
