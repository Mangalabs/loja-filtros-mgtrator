POSTGRES_DB=loja_filtros
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
POSTGRES_HOST_PORT=5433
BACKEND_BIND_ADDRESS=127.0.0.1
BACKEND_HOST_PORT=3333
# Opcional. Use se a senha do banco tiver caracteres reservados de URL como @, /, ?, # ou :.
# BACKEND_DATABASE_URL=postgres://postgres:replace-with-url-encoded-password@postgres:5432/loja_filtros
